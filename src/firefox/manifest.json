{
  "manifest_version": 3,
  "name": "Piped Redirect",
  "version": "1.3.0",
  "description": "Redirect YouTube videos and Shorts to your chosen Piped instance.",
  "icons": {
    "48": "./common/icon.png"
  },
  "permissions": ["contextMenus", "activeTab", "storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "PipedRedirect@janigma.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "action": {
    "default_icon": {
      "48": "./common/icon.png"
    },
    "default_popup": "./common/html/popup.html"
  },
  "background": {
    "scripts": ["./common/js/url-utils.js", "./js/background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "*://youtube.com/*",
        "*://www.youtube.com/*",
        "*://m.youtube.com/*",
        "*://music.youtube.com/*",
        "*://youtu.be/*"
      ],
      "js": ["./common/js/url-utils.js", "./js/content-script.js"],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "./common/html/options.html",
    "open_in_tab": true
  }
}
